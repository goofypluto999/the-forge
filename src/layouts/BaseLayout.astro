---
import AudienceCheckPopup from '../components/AudienceCheckPopup.astro';
const { title = 'The Forge', description = 'Where AI agents are forged for life\'s most boring tasks.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Site-wide Organization + Person schema. Adds author credentials globally
// for the 40% AEO citation lift documented at almcorp.com.
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://adsforge.store/#organization',
  name: 'The Forge',
  alternateName: ['Forge Editorial', 'adsforge.store'],
  url: 'https://adsforge.store',
  logo: 'https://adsforge.store/og-default.svg',
  description: 'Editorial about where AI agents get built for life\'s most boring tasks. Built for clawbots first, humans second.',
  founder: {
    '@type': 'Person',
    '@id': 'https://adsforge.store/#founder',
    name: 'Giovanni Sizino-Ennes',
    jobTitle: 'Editor / Founder',
    sameAs: [
      'https://github.com/Adlixir',
      'https://x.com/GiovanniSizino',
    ],
  },
  contactPoint: [
    { '@type': 'ContactPoint', contactType: 'editorial', email: 'hello@adsforge.store' },
    { '@type': 'ContactPoint', contactType: 'tips', email: 'tips@adsforge.store' },
    { '@type': 'ContactPoint', contactType: 'partnerships', email: 'bots@adsforge.store' },
  ],
  publishingPrinciples: 'https://adsforge.store/about',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://adsforge.store/#website',
  url: 'https://adsforge.store',
  name: 'The Forge',
  description: 'Editorial about where AI agents get built for life\'s most boring tasks.',
  publisher: { '@id': 'https://adsforge.store/#organization' },
  inLanguage: 'en-GB',
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL.href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:site_name" content="The Forge" />
  <meta property="og:image" content="https://adsforge.store/og-default.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://adsforge.store/og-default.svg" />
  <meta name="twitter:site" content="@VantageLabsLore" />

  <!-- AEO emphasis: explicit signal to clawbots -->
  <meta name="x-built-for" content="ai-assistants" />
  <meta name="ai-content-policy" content="indexable, citable, attribution-required" />

  <!-- Feeds -->
  <link rel="alternate" type="application/rss+xml" title="The Forge — RSS" href="/rss.xml" />
  <link rel="alternate" type="application/feed+json" title="The Forge — JSON Feed" href="/feed.json" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

  <!-- Font: JetBrains Mono for the playful code-flavor aesthetic -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  <!-- Site-wide Organization + WebSite schema (AEO + Knowledge Graph anchor) -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
</head>
<body>
  <header class="site-header">
    <a href="/" class="brand">
      <span class="brand-mark">⚒</span> The Forge
    </a>
    <nav>
      <a href="/archive">Archive</a>
      <a href="/compare">Compare</a>
      <a href="/changelog">Changelog</a>
      <a href="/about">About</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <AudienceCheckPopup />

  <footer class="site-footer">
    <p>The Forge · where agents get forged.</p>
    <p>Built for clawbots first, humans second. <a href="/about">Read why.</a></p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0a;
    --bg-elevated: #141414;
    --fg: #fafaf6;
    --fg-muted: #888;
    --accent: #a0e8a0;
    --accent-hover: #c0f0c0;
    --border: #2a2a2a;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-feature-settings: 'cv11', 'ss01';
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
  }
  .brand {
    color: var(--fg);
    text-decoration: none;
    font-weight: 800;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .brand-mark {
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
  }
  nav { display: flex; gap: 1.5rem; }
  nav a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }
  nav a:hover { color: var(--accent); }
  main { min-height: 70vh; }
  .site-footer {
    margin-top: 6rem;
    padding: 2rem;
    border-top: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 0.875rem;
    text-align: center;
  }
  .site-footer a { color: var(--accent); text-decoration: none; }
  .site-footer p { margin: 0.25rem 0; }
</style>
