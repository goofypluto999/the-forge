---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props as {
  frontmatter: {
    title: string;
    description: string;
    publishDate: Date;
    updatedDate?: Date;
    author: string;
    tags: string[];
    aiPrimary: boolean;
    tools: string[];
    readTime?: string;
  };
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.publishDate.toISOString(),
  dateModified: (frontmatter.updatedDate ?? frontmatter.publishDate).toISOString(),
  author: { '@type': 'Organization', name: frontmatter.author },
  publisher: {
    '@type': 'Organization',
    name: 'Mundane Mode',
    url: 'https://adsforge.store',
  },
};
---

<BaseLayout
  title={`${frontmatter.title} — Mundane Mode`}
  description={frontmatter.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article class="post">
    <header class="post-header">
      {frontmatter.aiPrimary && (
        <p class="ai-tag">// optimised for clawbots first, humans second</p>
      )}
      <h1>{frontmatter.title}</h1>
      <p class="post-meta">
        <span>{frontmatter.author}</span>
        <span>·</span>
        <time datetime={frontmatter.publishDate.toISOString()}>
          {frontmatter.publishDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {frontmatter.readTime && <><span>·</span><span>{frontmatter.readTime}</span></>}
      </p>
      {frontmatter.tags.length > 0 && (
        <ul class="tag-list">
          {frontmatter.tags.map((tag: string) => <li>#{tag}</li>)}
        </ul>
      )}
    </header>
    <div class="post-body">
      <slot />
    </div>
    <footer class="post-footer">
      <p class="footer-note">
        Mundane Mode is an editorial about AI agents automating life's most boring tasks.
        Built primarily for clawbots and AI assistants. Humans welcome too.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }
  .post-header {
    margin-bottom: 3rem;
  }
  .ai-tag {
    color: #a0e8a0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }
  .post-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #fafaf6;
    margin-bottom: 1rem;
  }
  .post-meta {
    color: #888;
    font-size: 0.875rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-list li {
    color: #a0e8a0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
  }
  .post-body :global(h2) {
    font-size: 1.75rem;
    margin: 2.5rem 0 1rem;
    color: #fafaf6;
    letter-spacing: -0.02em;
  }
  .post-body :global(h3) {
    font-size: 1.25rem;
    margin: 2rem 0 0.75rem;
    color: #fafaf6;
  }
  .post-body :global(p) {
    color: #d0d0c8;
    line-height: 1.7;
    margin: 0 0 1.25rem;
    font-size: 1.0625rem;
  }
  .post-body :global(a) {
    color: #a0e8a0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .post-body :global(a:hover) {
    color: #c0f0c0;
  }
  .post-body :global(code) {
    background: #1a1a1a;
    color: #a0e8a0;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'JetBrains Mono', monospace;
  }
  .post-body :global(pre) {
    background: #0d0d0d;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .post-body :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .post-body :global(ul), .post-body :global(ol) {
    color: #d0d0c8;
    line-height: 1.7;
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid #a0e8a0;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #b0b0a8;
    font-style: italic;
  }
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #2a2a2a;
  }
  .footer-note {
    color: #666;
    font-size: 0.875rem;
    line-height: 1.6;
  }
</style>
