---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// Anything published before today goes in the archive
const today = new Date();
today.setHours(0, 0, 0, 0);

const archived = allPosts.filter((p) => p.data.publishDate < today);

// Group by year-month for archive browsing
const byMonth = new Map<string, typeof archived>();
for (const post of archived) {
  const d = post.data.publishDate;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  if (!byMonth.has(key)) byMonth.set(key, []);
  byMonth.get(key)!.push(post);
}

const months = [...byMonth.entries()].sort((a, b) => b[0].localeCompare(a[0]));

const monthLabel = (key: string) => {
  const [year, month] = key.split('-');
  const d = new Date(Number(year), Number(month) - 1, 1);
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long' });
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://adsforge.store' },
    { '@type': 'ListItem', position: 2, name: 'Archive', item: 'https://mundanemode.com/archive/' },
  ],
};
---

<BaseLayout
  title="Archive — Mundane Mode"
  description="Older dispatches from Mundane Mode. AI agent workflows, MCP server reviews, automation guides. Published two per day, archived after 24 hours."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="archive-hero">
    <p class="kicker">// archive · everything older than today</p>
    <h1>Archive.</h1>
    <p class="lede">
      Two new dispatches a day. Anything older than today is here. {archived.length} posts and counting.
    </p>
  </section>

  <section class="archive-list">
    {months.map(([key, posts]) => (
      <div class="month-group">
        <h2>{monthLabel(key)}</h2>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/${post.slug}/`}>
                <time datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' })}
                </time>
                <span class="post-title">{post.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .archive-hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 5rem 1.5rem 2rem;
  }
  .kicker {
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    margin: 0 0 1.5rem;
    opacity: 0.7;
  }
  .archive-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
    color: var(--fg);
  }
  .lede {
    color: var(--fg-muted);
    font-size: 1rem;
    margin: 0;
  }
  .archive-list {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
  }
  .month-group {
    margin-bottom: 3rem;
  }
  .month-group h2 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .month-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .month-group li {
    padding: 0.5rem 0;
  }
  .month-group a {
    display: flex;
    gap: 1.5rem;
    color: var(--fg);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s ease;
  }
  .month-group a:hover {
    color: var(--accent);
  }
  .month-group time {
    color: var(--fg-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    flex-shrink: 0;
    width: 56px;
  }
  .post-title {
    flex: 1;
  }
</style>
